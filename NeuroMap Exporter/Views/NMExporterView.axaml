<UserControl
    x:Class="NeuroMap_Exporter.Views.NMExporterView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:NeuroMap_Exporter.ViewModels"
    d:DesignHeight="500"
    d:DesignWidth="800"
    x:DataType="vm:NMExporterViewModel"
    mc:Ignorable="d">

    <Design.DataContext>
        <vm:NMExporterViewModel />
    </Design.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="50" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock
            Grid.Row="0"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            FontWeight="DemiBold"
            Text="NeuroMap Exporter" />

        <DockPanel Grid.Row="1">
            <Grid
                Name="BottomGrid"
                Margin="0,0"
                DockPanel.Dock="Bottom"
                IsVisible="{Binding !NMExporterModel.HideProgress}">


                <Grid.RowDefinitions>
                    <RowDefinition Height="30" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Name="CurrentFile" Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Text="Current File" />

                    <TextBlock
                        Name="LocalFilePath"
                        Grid.Column="1"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="{Binding NMExporterModel.CurrentFile}" />
                </Grid>

                <Grid Name="ProgressGrid" Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="150" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="150" />
                    </Grid.ColumnDefinitions>

                    <Grid Name="ProgressLabels">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="10" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Grid.Row="0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Text="File Progress" />
                        <TextBlock
                            Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Text="Row Progress" />
                    </Grid>

                    <Border Grid.Column="1">
                        <Border.Effect>
                            <DropShadowDirectionEffect BlurRadius="15" ShadowDepth="3" />
                        </Border.Effect>

                        <Grid Name="ProgressBars">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="30" />
                                <RowDefinition Height="30" />
                                <RowDefinition Height="10" />
                            </Grid.RowDefinitions>

                            <ProgressBar
                                Name="FilesProgress"
                                Grid.Row="0"
                                Height="15"
                                Margin="5"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                Maximum="100"
                                Minimum="0"
                                Value="{Binding NMExporterModel.FilePercentage}" />
                            <TextBlock
                                Name="FilesPercent"
                                Grid.Row="0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding NMExporterModel.FilePercentageString}" />

                            <ProgressBar
                                Name="RowsProgress"
                                Grid.Row="1"
                                Height="15"
                                Margin="5"
                                BorderBrush="Gray"
                                BorderThickness="1"
                                Maximum="100"
                                Minimum="0"
                                Value="{Binding NMExporterModel.RowPercentage}" />

                            <TextBlock
                                Name="RowsPercent"
                                Grid.Row="1"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Text="{Binding NMExporterModel.RowPercentageString}" />
                        </Grid>
                    </Border>

                    <Grid Name="ProgressAmounts" Grid.Column="2">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="30" />
                            <RowDefinition Height="30" />
                            <RowDefinition Height="10" />
                        </Grid.RowDefinitions>

                        <TextBlock
                            Name="FilesRemaining"
                            Grid.Row="0"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="DemiBold"
                            Text="{Binding NMExporterModel.FileCompleteRatio}"
                            TextAlignment="Center" />

                        <TextBlock
                            Name="RowsRemaining"
                            Grid.Row="1"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontSize="12"
                            FontWeight="DemiBold"
                            Text="{Binding NMExporterModel.RowCompleteRatio}"
                            TextAlignment="Center" />
                    </Grid>
                </Grid>
            </Grid>

            <Grid Margin="25,0" DockPanel.Dock="Top">
                <Grid.RowDefinitions>
                    <RowDefinition Height="80" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="50" />
                        <RowDefinition Height="50" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125" />
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Height="25"
                            Margin="10,10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Text="Input Folder:" />

                        <TextBox
                            Grid.Column="1"
                            Width="300"
                            Height="25"
                            Margin="10,10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Text="{Binding NMExporterModel.InputFolder}" />

                        <Button
                            Name="btnImportSearchFolder"
                            Grid.Column="2"
                            Width="100"
                            Height="25"
                            Margin="5"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding ClkImportSearchFolder}"
                            Content="Search Folder"
                            FontSize="12" />

                        <Button
                            Name="btnUpsample"
                            Grid.Column="3"
                            Width="90"
                            Height="30"
                            Margin="10,10"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding ConvertAsync}"
                            Content="Convert"
                            CornerRadius="10"
                            FontSize="12"
                            IsEnabled="{Binding !NMExporterModel.DisableUpsample}" />
                    </Grid>

                    <Grid Grid.Row="1">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="125" />
                            <ColumnDefinition Width="300" />
                            <ColumnDefinition Width="150" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>

                        <TextBlock
                            Grid.Column="0"
                            Height="25"
                            Margin="10,10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Text="Output Folder:" />

                        <TextBox
                            Grid.Column="1"
                            Width="300"
                            Height="25"
                            Margin="10,10"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            FontSize="12"
                            Text="{Binding NMExporterModel.OutputFolder}" />

                        <Button
                            Name="btnExportSearchFolder"
                            Grid.Column="2"
                            Width="100"
                            Height="25"
                            Margin="5"
                            HorizontalAlignment="Left"
                            VerticalAlignment="Center"
                            HorizontalContentAlignment="Center"
                            VerticalContentAlignment="Center"
                            Command="{Binding ClkExportSearchFolder}"
                            Content="Search Folder"
                            FontSize="12" />
                    </Grid>
                </Grid>

                <Grid
                    Grid.Row="1"
                    Width="100"
                    Height="200"
                    Margin="100,25"
                    HorizontalAlignment="Left"
                    VerticalAlignment="Top">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                        <RowDefinition Height="40" />
                    </Grid.RowDefinitions>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="60" />
                        <ColumnDefinition Width="100" />
                    </Grid.ColumnDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Grid.Column="0"
                        Grid.ColumnSpan="3"
                        Margin="-70,0"
                        VerticalAlignment="Center"
                        Text="File types to process:" />

                    <TextBlock
                        Grid.Row="1"
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="Firings" />

                    <CheckBox
                        Name="CBFiring"
                        Grid.Row="1"
                        Grid.Column="1"
                        IsChecked="{Binding NMExporterModel.SelectFirings}" />


                    <TextBlock
                        Grid.Row="2"
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="MFR" />

                    <CheckBox
                        Name="CBMFR"
                        Grid.Row="2"
                        Grid.Column="1"
                        IsChecked="{Binding NMExporterModel.SelectMFR}" />


                    <TextBlock
                        Grid.Row="3"
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="MUAPs" />
                    <CheckBox
                        Name="CBMUAPs"
                        Grid.Row="3"
                        Grid.Column="1"
                        IsChecked="{Binding NMExporterModel.SelectMUAPS}" />


                    <TextBlock
                        Grid.Row="4"
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="Stats" />

                    <CheckBox
                        Name="CBStats"
                        Grid.Row="4"
                        Grid.Column="1"
                        IsChecked="{Binding NMExporterModel.SelectStats}" />


                    <TextBlock
                        Grid.Row="5"
                        Grid.Column="0"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Text="All" />

                    <CheckBox
                        Name="CBAll"
                        Grid.Row="5"
                        Grid.Column="1"
                        Command="{Binding ClkAll}"
                        IsChecked="{Binding NMExporterModel.SelectAll}" />
                </Grid>
            </Grid>
        </DockPanel>
    </Grid>

</UserControl>
